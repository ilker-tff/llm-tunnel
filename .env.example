# ── Required ─────────────────────────────────────────────────────────────────

# API key for authenticating requests (generate a strong random key)
API_KEY=your-secret-api-key-here

# ── Model ────────────────────────────────────────────────────────────────────

# Ollama model to download and serve (auto-downloaded on first start)
# Options: gemma4:31b (20GB), gemma4:26b (18GB), gemma4:e4b (9.6GB), gemma4:e2b (7.2GB)
# Also: qwen3.5:32b, llama4-scout, mistral, etc. — any model from ollama.com/library
MODEL=gemma4:31b

# ── Cloudflare Tunnel (optional) ─────────────────────────────────────────────

# To expose over the internet via Cloudflare Tunnel:
# 1. Go to https://one.dash.cloudflare.com → Networks → Tunnels → Create
# 2. Copy the tunnel token
# 3. Set the tunnel's public hostname to point to http://proxy:8080
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ── Advanced ─────────────────────────────────────────────────────────────────

# Rate limit (requests per minute per API key)
RATE_LIMIT_RPM=60

# Max memory for Ollama container
OLLAMA_MEMORY_LIMIT=32g
